# =====================================================================
#  MariaDB tuning for WordPress — mounted into /etc/mysql/conf.d/.
#  Tuned for HEAVY WooCommerce sites (lots of wp_options, postmeta,
#  wc_* tables, autoloaded data). The single most important knob is
#  innodb_buffer_pool_size: set it to ~50-70% of RAM given to the DB
#  so the hot WooCommerce/Elementor working set stays in memory.
# =====================================================================

[mysqld]
# --- Character set / collation (utf8mb4 everywhere) -----------------
character-set-server         = utf8mb4
collation-server             = utf8mb4_unicode_ci

# --- Connections ----------------------------------------------------
#  net_*_timeout + lock_wait_timeout raised so large migration imports
#  (Duplicator / WPvivid SQL restore) don't drop mid-transfer.
max_connections              = 150
max_allowed_packet           = 512M
wait_timeout                 = 600
interactive_timeout          = 600
connect_timeout              = 60
net_read_timeout             = 600
net_write_timeout            = 600
innodb_lock_wait_timeout     = 120

# --- InnoDB (the engine WordPress uses) -----------------------------
default_storage_engine       = InnoDB
innodb_buffer_pool_size      = 1G
innodb_buffer_pool_instances = 2
innodb_log_file_size         = 256M
# Durability: 1 = full ACID (flush+sync the redo log on every commit). This
# is the safe default for a WooCommerce shop — a host crash / power loss will
# NOT lose an already-confirmed order. Set to 2 (flush each commit, sync once
# per second) ONLY as an explicit performance profile where losing up to ~1s
# of committed writes on a hard crash is acceptable.
innodb_flush_log_at_trx_commit = 1
innodb_flush_method          = O_DIRECT
innodb_file_per_table        = 1
innodb_stats_on_metadata     = 0
innodb_io_capacity           = 1000
innodb_read_io_threads       = 4
innodb_write_io_threads      = 4

# --- Temp tables / sorting (Woo runs big GROUP BY / sort queries) ---
tmp_table_size               = 128M
max_heap_table_size          = 128M
join_buffer_size             = 8M
sort_buffer_size             = 8M

# --- Query / table caches -------------------------------------------
# Query cache is removed in modern MariaDB defaults; rely on Redis +
# InnoDB buffer pool instead. Table-open cache helps with many tables.
table_open_cache             = 4000

# --- Slow query log (handy for finding bad plugin queries) ----------
# OFF by default: when enabled it writes to the data dir on the db_data
# volume and is NOT auto-rotated, so it can slowly fill the volume. Turn
# it on only while diagnosing, then turn it back off:
#   set slow_query_log = 1 below, then: docker compose restart db
# When on, the file is /var/lib/mysql/<hostname>-slow.log (we deliberately
# set no explicit path — /var/log/mysql does not exist in the image, so
# pointing there would make MariaDB fail to open the file). Watch/truncate:
#   docker compose exec db sh -c 'ls -lh /var/lib/mysql/*-slow.log'
#   docker compose exec db sh -c ': > /var/lib/mysql/$(hostname)-slow.log'
# For continuous monitoring prefer a metrics exporter over an ever-growing log.
slow_query_log               = 0
long_query_time              = 2

[client]
default-character-set        = utf8mb4
