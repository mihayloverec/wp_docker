# =====================================================================
#  WordPress stack template (Elementor + WooCommerce ready)
#  Copy to .env and fill in real values before deploying.
# =====================================================================

# --- Stack identity --------------------------------------------------
# Used as the Compose project name and container/volume name prefix.
# Change this per site so multiple stacks can coexist on one host.
STACK_NAME=wordpress

# --- Domain / URL ----------------------------------------------------
DOMAIN=example.com
WP_HOME=https://example.com
WP_SITEURL=https://example.com

# --- Docker network shared with Nginx Proxy Manager ------------------
# Usually: npm_default, nginxproxymanager_default, proxy-nginx_default
PROXY_NETWORK=npm_default

# --- Contacts --------------------------------------------------------
LETSENCRYPT_EMAIL=you@example.com

# --- WordPress -------------------------------------------------------
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_DEBUG=0
# Host port for direct/local access. MUST be unique per site on the same
# server (8088, 8089, 8090, ...). Domain traffic goes via the proxy, not this.
WORDPRESS_LOCAL_PORT=8088
# Bind address for the host port. 127.0.0.1 = local only (safe, proxy still
# works). Set 0.0.0.0 only if you need direct external IP:port access.
WP_HTTP_BIND=127.0.0.1
# production | staging | development — keeps Site Health & plugins sane.
WP_ENVIRONMENT_TYPE=production

# Set true to lock the site (no plugin/theme/core changes) — useful
# once a project is finished and you want it frozen.
DISALLOW_FILE_MODS=false

# WordPress-level memory (PHP hard ceiling lives in php/php.ini = 1024M)
WP_MEMORY_LIMIT=1024M
WP_MAX_MEMORY_LIMIT=1024M

# --- MariaDB ---------------------------------------------------------
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD=CHANGE_ME_STRONG
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT

# --- Redis -----------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS
REDIS_MAXMEMORY=512mb

# --- Container memory limits (tune to your server's RAM) -------------
# Reservations = soft minimum, Limits = hard ceiling.
DB_MEM_LIMIT=2g
DB_MEM_RESERVATION=512m
REDIS_MEM_LIMIT=640m
REDIS_MEM_RESERVATION=128m
WP_MEM_LIMIT=2g
WP_MEM_RESERVATION=512m
WPCRON_MEM_LIMIT=256m

# --- Backups to S3-compatible storage (Timeweb, Selectel, AWS, ...) --
# Schedule / scope
BACKUP_HOUR=3              # hour (0-23) of the daily run, in TZ below
RETENTION_DAYS=14         # delete remote copies older than this
BACKUP_FILES=true         # also back up wp-content (uploads/themes/plugins)
BACKUP_ON_START=false     # run once immediately on container start (testing)
# Destination bucket + path (S3_PATH defaults to STACK_NAME if left blank)
S3_BUCKET=my-bucket
S3_PATH=
# Credentials / endpoint of your S3 provider
# Timeweb Cloud example: endpoint https://s3.timeweb.cloud , region ru-1
S3_ENDPOINT=https://s3.timeweb.cloud
S3_REGION=ru-1
S3_ACCESS_KEY=YOUR_S3_ACCESS_KEY
S3_SECRET_KEY=YOUR_S3_SECRET_KEY
# Leave as "Other" for Timeweb/Selectel; use "AWS" for real AWS S3.
S3_PROVIDER=Other

# --- Container timezone ----------------------------------------------
TZ=Europe/Moscow
